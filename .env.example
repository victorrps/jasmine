# Server
HOST=127.0.0.1
PORT=8080
RUST_LOG=docforge=debug,actix_web=info

# Database
DATABASE_URL=sqlite://docforge.db?mode=rwc

# Auth
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING_BEFORE_RUNNING
JWT_EXPIRY_MINUTES=15

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# API Key Security
API_KEY_PEPPER=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING_FOR_HMAC

# Future: OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# OAUTH_REDIRECT_BASE_URL=http://localhost:8080

# Claude API for schema extraction (optional — falls back to stub without it)
# ANTHROPIC_API_KEY=sk-ant-...

# Local OCR (defaults to finding binaries in PATH)
# TESSERACT_PATH=/usr/bin/tesseract
# PDFTOPPM_PATH=/usr/bin/pdftoppm

# PaddleOCR PP-StructureV3 serving (optional — enables layout-aware extraction
# with native Markdown output, table recognition, and heading detection).
# Mode controls routing:
#   fallback (default) — pdf_oxide first; Paddle only for scanned/broken PDFs
#   primary            — Paddle first for every PDF; pdf_oxide as fallback
# PADDLEOCR_URL=http://localhost:8868
# PADDLEOCR_TIMEOUT_SECS=120
# PADDLEOCR_MODE=fallback

# Stripe metered billing (optional — billing features disabled without it)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
